# Variabili d'ambiente per Radar Paranormale
# Copia questo file come .env.local e inserisci i tuoi valori

# Appwrite Cloud (gratuito su https://cloud.appwrite.io)
# 1. Crea un progetto su Appwrite
# 2. Aggiungi una Web platform con il tuo dominio
# 3. Crea un database con le collection descritte in README
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=il-tuo-project-id
NEXT_PUBLIC_APPWRITE_DB_ID=il-tuo-database-id
NEXT_PUBLIC_APPWRITE_LUOGHI_ID=id-collection-user-places
